    "item_type": "protocol",
    "item_id": "step_01",
    "original_context": "{\n  \"id\": \"step_01\",\n  \"title\": \"Preparation of Hematite Core\",\n  \"purpose\": \"To synthesize the 1.0 micron ellipsoidal hematite core.\",\n  \"instructions\": [\n    \"Dissolve iron(III) chloride in deionized water.\",\n    \"Add sodium hydroxide solution to precipitate iron hydroxide.\",\n    \"Heat the mixture to 90°C for 2 hours to form hematite particles.\",\n    \"Wash and dry the particles.\"\n  ],\n  \"parameters\": {\n    \"reagent_amounts\": [\n      \"Iron(III) chloride: 10 g\",\n      \"Sodium hydroxide: 5 g\"\n    ],\n    \"concentrations\": [\n      \"Iron(III) chloride: 0.1 M\"\n    ],\n    \"temperatures\": [\n      \"90°C\"\n    ],\n    \"durations\": [\n      \"2 hours\"\n    ],\n    \"volumes\": [\n      \"Deionized water: 100 mL\"\n    ],\n    \"equipment_settings\": [],\n    \"environmental_conditions\": [\n      \"Room temperature\"\n    ]\n  },\n  \"acceptance_criteria\": [\n    \"Hematite particles are ellipsoidal and 1.0 micron in size.\"\n  ],\n  \"common_failure_modes\": [\n    \"Non-uniform particle size\"\n  ],\n  \"troubleshooting\": [\n    \"Adjust reaction time or temperature if particles are not the correct size.\"\n  ],\n  \"safety_notes\": [\n    \"Handle chemicals with care and use appropriate PPE.\"\n  ],\n  \"source_reference_ids\": [\n    \"ev_9\",\n    \"ev_10\"\n  ],\n  \"editable\": true\n}",
    "correction": "I want to do the reaction with 6M NaOH and 2M FeCl3 at 100°C for 7 days in the oven, to get 1.2um hematite cubes",
    "reason": "this reaction is easier",
